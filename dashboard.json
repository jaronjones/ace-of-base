{
  "title": "IslandTime",
  "port": 8080,
  "grid_cols": 12,
  "grid_rows": 8,
  "theme": "tropical-dark",
  "widgets": [
    {
      "id": "clock-main",
      "type": "clock",
      "title": "Local Time",
      "col": 1,
      "row": 1,
      "col_span": 4,
      "row_span": 2,
      "refresh": 0,
      "config": {
        "timezone": "America/New_York"
      }
    },
    {
      "id": "weather-home",
      "type": "weather",
      "title": "Weather",
      "col": 5,
      "row": 1,
      "col_span": 4,
      "row_span": 2,
      "refresh": 900,
      "config": {
        "location": "New York City",
        "lat": "40.7128",
        "lon": "-74.0060",
        "unit": "fahrenheit"
      }
    },
    {
      "id": "bookmarks-dev",
      "type": "bookmark",
      "title": "Dev Links",
      "col": 9,
      "row": 1,
      "col_span": 4,
      "row_span": 2,
      "refresh": 0,
      "config": {
        "cols": 3,
        "links": [
          { "label": "GitHub", "url": "https://github.com", "icon": "🐙" },
          { "label": "Go Docs", "url": "https://pkg.go.dev", "icon": "🐹" },
          { "label": "HTMX", "url": "https://htmx.org", "icon": "⚡" },
          { "label": "DaisyUI", "url": "https://daisyui.com", "icon": "🌼" },
          { "label": "Tailwind", "url": "https://tailwindcss.com", "icon": "🌊" },
          { "label": "Claude", "url": "https://claude.ai", "icon": "🤖" }
        ]
      }
    },
    {
      "id": "todo-main",
      "type": "todo",
      "title": "Tasks",
      "col": 1,
      "row": 3,
      "col_span": 4,
      "row_span": 3,
      "refresh": 0,
      "config": {}
    }
  ]
}
