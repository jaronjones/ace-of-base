# Copy to .env for dev mode. Real env vars always take precedence.
# Lines starting with # are ignored.

# ───────── HTTP server ─────────
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8081
# HTTP_READ_TIMEOUT=5s
# HTTP_WRITE_TIMEOUT=10s
# HTTP_SHUTDOWN_TIMEOUT=30s

# ───────── Logging ─────────
# LOG_LEVEL: debug | info | warn | error
# LOG_LEVEL=info
# DEV_MODE auto-detects a TTY; set explicitly to force pretty/text logs and .env loading
# DEV_MODE=true

# ───────── Weather widget ─────────
# Required for the LOCAL_CLIMATE widget. Free key at https://app.tomorrow.io/
TOMORROW_IO_API_KEY=

# Fallback location shown before the user picks one (defaults: Tokyo)
# WEATHER_DEFAULT_LAT=35.6762
# WEATHER_DEFAULT_LON=139.6503
# WEATHER_DEFAULT_LABEL=Tokyo, Japan
